# ============================================================
# SciLens Backend — Variables de entorno
# Copia este archivo como .env y rellena los valores
# ============================================================

# ── OpenRouter ──────────────────────────────────────────────
# 1. Ve a https://openrouter.ai → Sign up → Keys → Create key
# 2. SOLO modelos gratuitos (sufijo :free)
OPENROUTER_API_KEY=sk-or-v1-...

# Modelo LLM principal — SOLO gratuitos (:free)
#   deepseek/deepseek-chat-v3-0324:free   (recomendado — maneja papers largos)
#   meta-llama/llama-3.3-70b-instruct:free
#   mistralai/mistral-small-3.1-24b-instruct:free
LLM_MODEL=deepseek/deepseek-chat-v3-0324:free

# Modelo de respaldo — se usa si el principal falla o está rate-limited
LLM_MODEL_FALLBACK=meta-llama/llama-3.3-70b-instruct:free

# ── Jina AI (embeddings gratuitos) ─────────────────────────
# 1. Ve a https://jina.ai → Get API Key (1M tokens/mes gratis)
JINA_API_KEY=jina_...

# ── Supabase ────────────────────────────────────────────────
# Settings → API → usar la SERVICE ROLE key (no la anon)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── CORS ────────────────────────────────────────────────────
# Local: http://localhost:3000
# Producción: https://tu-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── APIs de enriquecimiento científico ─────────────────────
# TODAS gratuitas. Las keys son OPCIONALES — solo suben los rate limits.
# Sin key funcionan igual, solo con límites más bajos.
#
# NCBI / PubMed (mejora rate limit de ClinicalTrials/E-utilities):
#   https://www.ncbi.nlm.nih.gov/account/  → Settings → API Key Management
NCBI_API_KEY=

# OpenFDA (sube de 240 a 120.000 requests/día):
#   https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=
