# ============================================================
# SciLens Backend — Variables de entorno
# Copia este archivo como .env y rellena los valores
# ============================================================

# ── Proveedor LLM (endpoint compatible con OpenAI) ──────────
# El cliente LLM es agnóstico: sirve OpenRouter (cloud) u Ollama (local) con
# solo cambiar estas 4 variables. La lógica de análisis NO cambia.
#
# Los modelos gratis de OpenRouter SE DEPRECAN a menudo. Verifica que existan:
#   GET https://openrouter.ai/api/v1/models
#
# ── Opción A: OpenRouter (cloud, por defecto) ──
# 1. https://openrouter.ai → Sign up → Keys → Create key
# 2. SOLO modelos gratuitos (sufijo :free)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-...
LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
LLM_MODEL_FALLBACK=meta-llama/llama-3.3-70b-instruct:free

# OPENROUTER_API_KEY se mantiene por retrocompatibilidad: si LLM_API_KEY está
# vacío, se usa este. En prod (Fly) la key vive como secret con este nombre.
OPENROUTER_API_KEY=sk-or-v1-...

# ── Opción B: Ollama (local) ──
# Requiere `ollama serve` corriendo Y el backend ejecutándose en TU máquina
# (el deploy de Fly NO puede alcanzar tu localhost). Descomenta y comenta la A:
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_API_KEY=ollama                # Ollama lo ignora, pero el SDK exige un valor
#   LLM_MODEL=qwen3:8b                # bueno con JSON; `ollama pull qwen3:8b`
#   LLM_MODEL_FALLBACK=llama3.2:3b    # rápido; `ollama pull llama3.2:3b`

# ── Jina AI (embeddings gratuitos) ─────────────────────────
# 1. Ve a https://jina.ai → Get API Key (1M tokens/mes gratis)
JINA_API_KEY=jina_...

# ── Supabase ────────────────────────────────────────────────
# Settings → API → usar la SERVICE ROLE key (no la anon)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── CORS ────────────────────────────────────────────────────
# Local: http://localhost:3000
# Producción: https://tu-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── APIs de enriquecimiento científico ─────────────────────
# TODAS gratuitas. Las keys son OPCIONALES — solo suben los rate limits.
# Sin key funcionan igual, solo con límites más bajos.
#
# NCBI / PubMed (mejora rate limit de ClinicalTrials/E-utilities):
#   https://www.ncbi.nlm.nih.gov/account/  → Settings → API Key Management
NCBI_API_KEY=

# OpenFDA (sube de 240 a 120.000 requests/día):
#   https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=
