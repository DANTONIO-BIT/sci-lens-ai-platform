# ============================================================
# SciLens Backend — Variables de entorno
# Copia este archivo como .env y rellena los valores
# ============================================================

# ── OpenRouter ──────────────────────────────────────────────
# 1. Ve a https://openrouter.ai → Sign up → Keys → Create key
# 2. Tiene modelos gratuitos disponibles
OPENROUTER_API_KEY=sk-or-v1-...

# Modelo LLM — opciones gratuitas:
#   meta-llama/llama-3.3-70b-instruct:free
#   mistralai/mistral-small-3.1-24b-instruct:free
#   google/gemini-2.0-flash-001  (muy barato, $0.10/1M)
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Jina AI (embeddings gratuitos) ─────────────────────────
# 1. Ve a https://jina.ai → Get API Key (1M tokens/mes gratis)
JINA_API_KEY=jina_...

# ── Supabase ────────────────────────────────────────────────
# Settings → API → usar la SERVICE ROLE key (no la anon)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── CORS ────────────────────────────────────────────────────
# Local: http://localhost:3000
# Producción: https://tu-app.vercel.app
FRONTEND_URL=http://localhost:3000
